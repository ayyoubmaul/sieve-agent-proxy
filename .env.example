# ─── Proxy ─────────────────────────────────────────────
PORT=4141

# Where to forward requests (OpenAI, Anthropic, OpenRouter, etc.)
TARGET_URL=https://api.anthropic.com

# ─── Compression ───────────────────────────────────────
COMPRESSION=true
SUMMARIZE_OLD_TURNS=true
SUMMARIZE_AFTER=10        # summarise turns older than this many messages
KEEP_RECENT_TURNS=4       # always keep last N turns verbatim

# ─── Tool-result compaction ────────────────────────────
# Content-aware shrinking of the bulkiest thing a coding agent resends every
# turn: tool output. Bloated JSON keeps its keys/structure but elides long
# values + caps big arrays; logs dedup repeated lines; SQL/table dumps keep the
# first/last rows. Deterministic, so an already-seen result stays byte-identical
# across turns and the upstream prompt-cache prefix is preserved.
TOOL_COMPACTION=true
TOOL_COMPACT_MIN_BYTES=1024   # only touch tool results larger than this
TOOL_COMPACT_MAX_STRING=512   # truncate JSON string values longer than this (runes)
TOOL_COMPACT_MAX_ARRAY=24     # cap JSON arrays longer than this (keep head + tail)
TOOL_COMPACT_MAX_LINES=60     # cap line-oriented output longer than this (lines)

# Retrieval / context rolling. When on, the full original of each compacted tool
# result is saved under ~/.sieve/store and the compacted form carries a
# sieve_fetch(ref) marker. Register the fetch tool with your agent so it can pull
# an original back on demand:  claude mcp add sieve -- sieve mcp
# Off by default: only enable once the MCP server is registered, otherwise the
# marker advertises a tool the agent can't call.
TOOL_RETRIEVAL=false

# Name the compaction marker tells the model to call to fetch an original. It
# must match the tool name the AGENT sees — and MCP hosts prefix the server name
# onto the bare "fetch" tool, so a server registered as `sieve` exposes it as
# "sieve_fetch" (the default). If your host shows a different name (e.g.
# "sieve_sieve_fetch" from a legacy registration), set it here so the marker
# names a tool the model can actually call.
RETRIEVAL_TOOL_NAME=sieve_fetch

# Intent-aware compaction. Bias what's kept by the user's latest message: JSON
# values under a matching key are kept fuller, and log lines / table rows that
# match are protected from elision. Stays cache-safe because each original's
# compacted bytes are pinned on first sight and reused verbatim afterwards, so
# the prompt-cache prefix doesn't move even though intent changes per turn.
TOOL_INTENT=false

# ─── Token Cache (exact SHA-256 match) ─────────────────
TOKEN_CACHE=true
TOKEN_CACHE_TTL=3600      # seconds
TOKEN_CACHE_MAX=1000      # max entries (LRU eviction)

# ─── Semantic Cache (TF-IDF cosine similarity) ─────────
# Non-streaming requests only. Most coding agents stream, so L2 won't run for
# them — and that's intentional: returning a "similar" cached answer to a
# slightly different coding prompt would be wrong code. Useful for repetitive
# NON-streaming workloads (classification, repeated Q&A).
SEMANTIC_CACHE=true
SEMANTIC_THRESHOLD=0.82   # 0–1, higher = stricter. 0.82 ≈ near-duplicates only;
                         # try 0.5–0.7 to catch looser matches (more false hits).
SEMANTIC_CACHE_MAX=500

# ─── Output token reduction (request-side; opt-in) ─────
# Output tokens bill higher than input, so /stats now always measures them.
# This section additionally trims *generated* tokens by lowering reasoning
# effort. It trades some response quality for cost, so it is off by default.
OUTPUT_POLICY=false        # master switch
REASONING_PROFILE=off      # off | anthropic | openai | auto (which effort field)
ROUTINE_EFFORT=            # low | medium | high — downgrade target (never raises)
MAX_OUTPUT_TOKENS=0        # clamp the output ceiling (0 = off; guardrail, never truncates below the client's own cap)
TRIM_OUTPUT=false          # inject a conciseness directive (drops ceremony / restated code)
OUTPUT_STYLE=concise       # concise | terse
OUTPUT_DIRECTIVE=          # full custom directive text (overrides OUTPUT_STYLE)
TRIM_RESPONSE=false        # code-safe whitespace trim of the reply (non-stream; shrinks next-turn input)

# ─── PromptAlign — provider-side prompt-cache optimizer (request-side; opt-in) ─────
# Complements the L1/L1n/L2 response cache: where that saves a whole call, this
# discounts the *input* tokens sieve still sends by raising the provider's own
# prompt-cache hit rate (Anthropic cache_control; OpenAI automatic prefix cache).
# It is the primary saver when the response cache is disabled. Client-set
# cache_control is always respected — injection only fills in when the client set
# none. Off by default.
PROMPT_ALIGN=false                 # master switch
PROMPT_ALIGN_INJECT=true           # inject Anthropic cache_control only when client set none
PROMPT_ALIGN_REORDER=true          # hoist a leading system run to the front (conservative; OpenAI)
PROMPT_ALIGN_NORMALIZE=true        # byte-normalize the prefix (code-safe whitespace + JSON key order)
PROMPT_ALIGN_MAX_BREAKPOINTS=3     # Anthropic honors max 4; 3 covers tools + system + history
PROMPT_ALIGN_SET_BETA=true         # merge prompt-caching beta header when injecting (GA endpoints ignore it)
